# OpenAI 또는 Bedrock 관련 설정
OPENAI_API_KEY=

# MongoDB Atlas 연결 문자열
MONGODB_URI=
MONGODB_DB=cafe_reviews
MONGODB_COLLECTION=reviews

# MySQL/PlanetScale 연결 정보
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=cafe_menu

# 크롤링 기본 설정
CRAWL_MAX_PAGES=3

# FastAPI 설정
API_HOST=0.0.0.0
API_PORT=8000

# 추천 가중치 설정 (긍정 맛평가 가중치)
POSITIVE_TASTE_WEIGHT=1.5
